{% extends 'base.html.twig' %}

{% set active = 'events' %}

{% block title %}My Reservations - Event Studio{% endblock %}

{% block body %}
<div class="protected-page" id="reservationsPage">
<section class="hero">
    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1rem;">
        <div>
            <h1>My Reservations</h1>
            <p>Review your current bookings and cancel when your plans change.</p>
        </div>
        <button id="userLogoutButton" class="alt" type="button" style="min-width: auto; padding: 0.6rem 1.2rem; height: fit-content;">Logout</button>
    </div>
    <div class="hero-actions">
        <a class="ghost" href="{{ path('frontend_events') }}">Back to Event Catalog</a>
    </div>
</section>

<section class="grid">
    <article class="panel">
        <h2>Reservation History</h2>
        <button id="refreshReservations" class="alt">Refresh</button>
        <div class="note">Only active bookings can be cancelled.</div>
        <div id="reservationFlash" class="flash" style="display:none;"></div>
        <div id="reservationList" class="list"></div>
    </article>
</section>
</div>
{% endblock %}

{% block javascripts %}
<script>
async function loadReservations() {
    const data = await EventApp.request('/reservations/me');
    const list = document.getElementById('reservationList');
    list.innerHTML = '';

    if (!data.items || data.items.length === 0) {
        list.innerHTML = '<div class="card">No reservations yet.</div>';
        return;
    }

    data.items.forEach((item) => {
        const card = document.createElement('article');
        card.className = 'card';
        card.innerHTML = `
            <div class="row">
                <strong>${item.event ? item.event.title : 'Unknown event'}</strong>
                <span class="status ${item.status === 'active' ? 'ok' : 'warn'}">${item.status}</span>
            </div>
            <div><small>Booked at: ${new Date(item.createdAt).toLocaleString()}</small></div>
            <div class="row" style="margin-top:.6rem;">
                <button class="alt" data-id="${item.id}" ${item.status !== 'active' ? 'disabled' : ''}>Cancel</button>
            </div>
        `;
        list.appendChild(card);
    });

    list.querySelectorAll('button[data-id]').forEach((btn) => {
        btn.addEventListener('click', async () => {
            try {
                await EventApp.request(`/reservations/${btn.dataset.id}`, { method: 'DELETE' });
                EventApp.flash('reservationFlash', 'Reservation cancelled.');
                await loadReservations();
            } catch (error) {
                EventApp.flash('reservationFlash', error.message);
            }
        });
    });
}

document.getElementById('refreshReservations').addEventListener('click', () => {
    loadReservations().catch((error) => EventApp.flash('reservationFlash', error.message));
});

(async function initReservationPage() {
    const profile = await EventApp.protectPage({ requireUser: true });
    if (!profile) {
        return;
    }

    EventApp.showProtectedPage('#reservationsPage');

    loadReservations().catch((error) => EventApp.flash('reservationFlash', error.message));

    // Add logout button handler
    const logoutButton = document.getElementById('userLogoutButton');
    if (logoutButton) {
        logoutButton.addEventListener('click', () => {
            EventApp.clearToken();
            window.location.href = '/app/login';
        });
    }
})();
</script>
{% endblock %}
