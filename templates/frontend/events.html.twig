{% extends 'base.html.twig' %}

{% set active = 'events' %}

{% block title %}User Space - Event Studio{% endblock %}

{% block body %}
<div class="protected-page" id="userSpacePage">
<section class="hero">
    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1rem;">
        <div>
            <h1>Reserve Your Next Event</h1>
            <p>Find the best upcoming events, filter quickly, and reserve your seat in one click.</p>
        </div>
        <div style="display:flex; gap:0.6rem;">
            <button id="createPasskeyButton" class="ghost" type="button" style="min-width: auto; padding: 0.6rem 1.2rem; height: fit-content;">Create Passkey</button>
            <button id="userLogoutButton" class="alt" type="button" style="min-width: auto; padding: 0.6rem 1.2rem; height: fit-content;">Logout</button>
        </div>
    </div>
    <div class="hero-actions">
        <a class="ghost" href="{{ path('frontend_reservations') }}">View My Reservations</a>
    </div>
</section>

<section class="grid">
    <article class="panel">
        <h2>Available Events</h2>
        <div id="eventLoading" class="loading-indicator" style="display:none;">Loading events...</div>
        <div id="eventList" class="list"></div>
        <div id="eventPagination" class="pagination" style="display:none;">
            <button id="eventsPrev" class="alt" type="button">Previous</button>
            <span id="eventsMeta"></span>
            <button id="eventsNext" class="alt" type="button">Next</button>
        </div>
        <div id="eventFlash" class="flash" style="display:none;"></div>
    </article>
</section>

<!-- Reservation Modal -->
<div id="reservationModal" class="modal" style="display:none;">
    <div class="modal-overlay"></div>
    <div class="modal-content">
        <div class="modal-header">
            <h2>Confirm Your Reservation</h2>
            <button id="modalClose" class="modal-close" type="button">&times;</button>
        </div>
        <form id="reservationForm" class="form">
            <input type="hidden" id="reservationEventId" value="">
            <div class="form-group">
                <label for="reservationFirstName">First Name</label>
                <input id="reservationFirstName" type="text" required>
                <small id="reservationFirstNameError" class="error" style="display:none;"></small>
            </div>
            <div class="form-group">
                <label for="reservationLastName">Last Name</label>
                <input id="reservationLastName" type="text" required>
                <small id="reservationLastNameError" class="error" style="display:none;"></small>
            </div>
            <div class="form-group">
                <label for="reservationEmail">Email</label>
                <input id="reservationEmail" type="email" required>
                <small id="reservationEmailError" class="error" style="display:none;"></small>
            </div>
            <div class="modal-actions">
                <button id="modalCancel" class="alt" type="button">Cancel</button>
                <button id="modalSubmit" class="accent" type="submit">Confirm Reservation</button>
            </div>
            <div id="reservationFlash" class="flash" style="display:none;"></div>
        </form>
    </div>
</div>
</div>
{% endblock %}

{% block javascripts %}
<script>
const eventsState = {
    page: 1,
    limit: 6,
};

function syncPageFromUrl() {
    const params = new URLSearchParams(window.location.search);
    eventsState.page = Math.max(1, parseInt(params.get('page') || '1', 10));
}

function syncUrlPage() {
    const params = new URLSearchParams();
    params.set('page', String(eventsState.page));

    const query = params.toString();
    const nextUrl = `${window.location.pathname}${query ? `?${query}` : ''}`;
    window.history.replaceState({}, '', nextUrl);
}

function setEventLoading(isLoading) {
    const loading = document.getElementById('eventLoading');
    const list = document.getElementById('eventList');
    if (loading) {
        loading.style.display = isLoading ? 'block' : 'none';
    }
    if (list) {
        list.style.opacity = isLoading ? '0.5' : '1';
    }
}

function renderPagination(total, page, limit) {
    const pagination = document.getElementById('eventPagination');
    const prev = document.getElementById('eventsPrev');
    const next = document.getElementById('eventsNext');
    const meta = document.getElementById('eventsMeta');

    const totalPages = Math.max(1, Math.ceil(total / limit));
    const hasPrev = page > 1;
    const hasNext = page < totalPages;

    pagination.style.display = total > 0 ? 'flex' : 'none';
    prev.disabled = !hasPrev;
    next.disabled = !hasNext;
    meta.textContent = `Page ${page} of ${totalPages} - ${total} result(s)`;
}

function openReservationModal(eventId) {
    const modal = document.getElementById('reservationModal');
    const profile = EventApp.getProfile();
    
    // Pre-fill form with user data if available
    if (profile && profile.firstName) {
        document.getElementById('reservationFirstName').value = profile.firstName;
    }
    if (profile && profile.lastName) {
        document.getElementById('reservationLastName').value = profile.lastName;
    }
    if (profile && profile.email) {
        document.getElementById('reservationEmail').value = profile.email;
    }
    
    document.getElementById('reservationEventId').value = eventId;
    modal.style.display = 'flex';
}

function closeReservationModal() {
    const modal = document.getElementById('reservationModal');
    modal.style.display = 'none';
    document.getElementById('reservationForm').reset();
    clearReservationErrors();
}

function clearReservationErrors() {
    ['reservationFirstName', 'reservationLastName', 'reservationEmail'].forEach(fieldId => {
        const errorId = fieldId + 'Error';
        const error = document.getElementById(errorId);
        if (error) {
            error.style.display = 'none';
            error.textContent = '';
        }
        const field = document.getElementById(fieldId);
        if (field) {
            field.classList.remove('error');
        }
    });
}

function setReservationFieldError(fieldId, message) {
    const field = document.getElementById(fieldId);
    const errorId = fieldId + 'Error';
    const error = document.getElementById(errorId);
    if (field) {
        field.classList.add('error');
    }
    if (error) {
        error.textContent = message;
        error.style.display = 'block';
    }
}

async function loadEvents() {
    EventApp.clearFlash('eventFlash');
    setEventLoading(true);

    const data = await EventApp.request(`/events?page=${eventsState.page}&limit=${eventsState.limit}`);
    syncUrlPage();

    const list = document.getElementById('eventList');
    list.innerHTML = '';

    if (!data.items || data.items.length === 0) {
        list.innerHTML = '<div class="card"><strong>No events found.</strong><div>Try adjusting filters and search again.</div></div>';
        renderPagination(0, eventsState.page, eventsState.limit);
        setEventLoading(false);
        return;
    }

    data.items.forEach((eventItem) => {
        const node = document.createElement('article');
        node.className = 'card';
        node.innerHTML = `
            <div class="row">
                <strong>${eventItem.title}</strong>
                <span class="status ${eventItem.availableSeats > 0 ? 'ok' : 'warn'}">
                    ${eventItem.availableSeats} seats left
                </span>
            </div>
            <div>${eventItem.description || ''}</div>
            <div><small>${new Date(eventItem.date).toLocaleString()} - ${eventItem.location}</small></div>
            <div class="row" style="margin-top:.6rem;">
                <button class="accent" data-id="${eventItem.id}" ${eventItem.availableSeats > 0 ? '' : 'disabled'}>Reserve</button>
            </div>
        `;
        list.appendChild(node);
    });

    list.querySelectorAll('button[data-id]').forEach((btn) => {
        btn.addEventListener('click', () => {
            openReservationModal(btn.dataset.id);
        });
    });

    renderPagination(data.total || data.items.length, data.page || eventsState.page, data.limit || eventsState.limit);
    setEventLoading(false);
}

// Modal event handlers
document.getElementById('modalClose').addEventListener('click', closeReservationModal);
document.getElementById('modalCancel').addEventListener('click', closeReservationModal);

document.getElementById('reservationForm').addEventListener('submit', async function (e) {
    e.preventDefault();
    
    clearReservationErrors();
    EventApp.clearFlash('reservationFlash');
    
    const eventId = document.getElementById('reservationEventId').value;
    const firstName = document.getElementById('reservationFirstName').value.trim();
    const lastName = document.getElementById('reservationLastName').value.trim();
    const email = document.getElementById('reservationEmail').value.trim();
    
    let hasError = false;
    
    if (!firstName) {
        setReservationFieldError('reservationFirstName', 'First name is required.');
        hasError = true;
    }
    
    if (!lastName) {
        setReservationFieldError('reservationLastName', 'Last name is required.');
        hasError = true;
    }
    
    if (!email) {
        setReservationFieldError('reservationEmail', 'Email is required.');
        hasError = true;
    } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        setReservationFieldError('reservationEmail', 'Please enter a valid email address.');
        hasError = true;
    }
    
    if (hasError) {
        return;
    }
    
    try {
        const submitButton = document.getElementById('modalSubmit');
        EventApp.setLoading(submitButton, 'Confirming...');
        
        const reservationResponse = await EventApp.request(`/events/${eventId}/reservations`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                firstName,
                lastName,
                email,
            }),
        });

        if (reservationResponse && reservationResponse.emailSent === false) {
            EventApp.flash('eventFlash', 'Reservation confirmed, but email was not sent. Verify SMTP/Mailpit is running.');
        } else {
            EventApp.flash('eventFlash', 'Reservation confirmed! Check your email for details.');
        }
        closeReservationModal();
        await loadEvents();
    } catch (error) {
        EventApp.flash('reservationFlash', error.message);
    } finally {
        EventApp.clearLoading(document.getElementById('modalSubmit'));
    }
});

// Close modal when clicking on overlay
document.getElementById('reservationModal').addEventListener('click', function (e) {
    if (e.target === this) {
        closeReservationModal();
    }
});

document.getElementById('eventsPrev').addEventListener('click', async function () {
    if (eventsState.page <= 1) return;
    eventsState.page -= 1;
    try {
        await loadEvents();
    } catch (error) {
        EventApp.flash('eventFlash', error.message);
        setEventLoading(false);
    }
});

document.getElementById('eventsNext').addEventListener('click', async function () {
    eventsState.page += 1;
    try {
        await loadEvents();
    } catch (error) {
        EventApp.flash('eventFlash', error.message);
        setEventLoading(false);
    }
});

(async function initUserSpace() {
    const profile = await EventApp.protectPage({ requireUser: true });
    if (!profile) {
        return;
    }

    EventApp.showProtectedPage('#userSpacePage');

    syncPageFromUrl();
    loadEvents().catch((error) => {
        EventApp.flash('eventFlash', error.message);
        setEventLoading(false);
    });

    // Add logout button handler
    const logoutButton = document.getElementById('userLogoutButton');
    if (logoutButton) {
        logoutButton.addEventListener('click', () => {
            EventApp.clearToken();
            window.location.href = '/app/login';
        });
    }

    const createPasskeyButton = document.getElementById('createPasskeyButton');
    if (createPasskeyButton) {
        createPasskeyButton.addEventListener('click', async () => {
            EventApp.clearFlash('eventFlash');
            try {
                EventApp.setLoading(createPasskeyButton, 'Generating...');
                const data = await EventApp.request('/passkey/create', { method: 'POST' });
                const passkey = data && data.passkey ? data.passkey : '';
                if (!passkey) {
                    throw new Error('Could not generate passkey.');
                }

                EventApp.flash('eventFlash', `Your new passkey: ${passkey}. Save it now.`);
            } catch (error) {
                EventApp.flash('eventFlash', error.message);
            } finally {
                EventApp.clearLoading(createPasskeyButton);
            }
        });
    }
})();
</script>
{% endblock %}
