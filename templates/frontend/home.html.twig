{% extends 'base.html.twig' %}

{% set active = 'home' %}

{% block title %}Home - Event Studio{% endblock %}

{% block body %}
<section class="hero">
    <h1>Plan. Reserve. Track.</h1>
    <p>
        This interface connects directly to your Symfony JWT API. Use the login page to store your token,
        browse events, reserve seats, and manage reservations from one place.
    </p>
</section>

<section class="grid">
    <article class="panel">
        <h2>Quick Start</h2>
        <div class="kpi">
            <div class="tile">
                <div class="label">Step 1</div>
                <div class="value">Login</div>
                <div>Go to Login and get your JWT.</div>
            </div>
            <div class="tile">
                <div class="label">Step 2</div>
                <div class="value">Explore</div>
                <div>Open Events and reserve available seats.</div>
            </div>
            <div class="tile">
                <div class="label">Step 3</div>
                <div class="value">Manage</div>
                <div>Track and cancel bookings in My Reservations.</div>
            </div>
            <div class="tile">
                <div class="label">Step 4</div>
                <div class="value">Admin</div>
                <div>Use Admin page for event CRUD with admin token.</div>
            </div>
        </div>
    </article>
</section>
{% endblock %}
