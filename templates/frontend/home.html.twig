{% extends 'base.html.twig' %}

{% set active = 'home' %}
{% set hide_chrome = true %}

{% block title %}Welcome - Event Studio{% endblock %}

{% block body_class %}landing-body{% endblock %}

{% block body %}
<section class="landing-shell">
    <div class="landing-copy">
        <div class="landing-badge">Event Reservation</div>
        <h1>Appointment Booking</h1>
        <p>
            Book your events with a clean and fast flow.
            Sign in to continue to your personal reservation space or admin dashboard.
        </p>
        <div class="hero-actions">
            <a class="cta" href="{{ path('frontend_login') }}">Sign In</a>
        </div>
    </div>
    <div class="landing-visual" aria-hidden="true">
        <div class="calendar-card">
            <div class="calendar-head">October</div>
            <div class="calendar-grid">
                {% for i in 1..35 %}
                    <span class="cell {{ i in [11, 18, 25] ? 'marked' : '' }}">{{ i <= 31 ? i : '' }}</span>
                {% endfor %}
            </div>
        </div>
        <div class="decor decor-a"></div>
        <div class="decor decor-b"></div>
        <div class="clock-dot"></div>
    </div>
</section>


{% endblock %}
