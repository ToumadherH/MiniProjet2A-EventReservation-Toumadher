<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="api-csrf-token" content="{{ csrf_token('api_action') }}">
    <title>{% block title %}Event Reservation{% endblock %}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:wght@500;700;800&family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
    {% block stylesheets %}{% endblock %}
</head>
<body class="{% block body_class %}{% endblock %}">
<div class="ambient"></div>
<div class="shell">
    {% set hideChrome = hide_chrome|default(false) %}
    {% if not hideChrome %}
    <header class="topbar">
        <a class="brand" href="{{ path('frontend_home') }}">Event Studio</a>
        <nav class="menu">
            {% set active = active|default('home') %}
            <a class="{{ active == 'home' ? 'active' : '' }}" href="{{ path('frontend_home') }}">Home</a>
            <a class="{{ active == 'login' ? 'active' : '' }}" data-guest-only href="{{ path('frontend_login') }}">Sign In</a>
            <a class="{{ active == 'events' ? 'active' : '' }}" data-user-link style="display:none;" href="{{ path('frontend_events') }}">User Space</a>
            <a class="{{ active == 'admin' ? 'active' : '' }}" data-admin-link style="display:none;" href="{{ path('frontend_admin') }}">Admin Dashboard</a>
        </nav>
        
    </header>
    {% endif %}

    <main class="page-content">
        {% block body %}{% endblock %}
    </main>

    {% if not hideChrome %}
    <footer>
        Built for smooth event booking and fast admin operations.
    </footer>
    {% endif %}
</div>

<script src="{{ asset('scripts/app-ui.js') }}"></script>
{% block javascripts %}{% endblock %}
</body>
</html>
